<Window x:Class="CustomShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Background="#121212"
        Height="55"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#2b2b2b"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#4a4a4a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransparentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="Win10Button" TargetType="Button">
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="Spotlight" Background="{TemplateBinding Background}" Opacity="0"/>
                            <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Spotlight" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Spotlight" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <Border x:Name="TaskbarContainer"
                Background="#171717"
                CornerRadius="6"
                Margin="6">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="StartButtonColumn" Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Width="34"
                        Height="34"
                        Margin="10,0,10,0"
                        VerticalAlignment="Center"
                        Click="StartButton_Click"
                        PreviewMouseRightButtonUp="StartButton_RightClick"
                        Style="{StaticResource TransparentButton}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Grid Width="18" Height="18" VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" Background="#00a4ef" Margin="0,0,1,1" CornerRadius="1.5"/>
                            <Border Grid.Row="0" Grid.Column="1" Background="#00a4ef" Margin="1,0,0,1" CornerRadius="1.5"/>
                            <Border Grid.Row="1" Grid.Column="0" Background="#00a4ef" Margin="0,1,1,0" CornerRadius="1.5"/>
                            <Border Grid.Row="1" Grid.Column="1" Background="#00a4ef" Margin="1,1,0,0" CornerRadius="1.5"/>
                        </Grid>
                    </StackPanel>
                </Button>

                <ScrollViewer x:Name="TaskbarScrollViewer"
                              Grid.Column="1"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Hidden"
                              PreviewMouseWheel="TaskbarScrollViewer_PreviewMouseWheel"
                              PanningMode="HorizontalOnly">

                    <StackPanel x:Name="TaskbarPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </ScrollViewer>

            </Grid>
        </Border>

        <Popup x:Name="StartMenu"
               Placement="Top"
               PlacementTarget="{Binding ElementName=StartButton}"
               StaysOpen="False"
               AllowsTransparency="True"
               VerticalOffset="-10"
               Closed="StartMenu_Closed">
            <Border Width="220"
                    Background="#1f1f1f"
                    CornerRadius="8"
                    Margin="10">
                <StackPanel Margin="10">
                    <Button Margin="2" Height="40" HorizontalContentAlignment="Stretch" Style="{StaticResource FlatButton}" Click="LaunchExplorer">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xEC50;" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center" Width="30" TextAlignment="Center"/>
                            <TextBlock Text="Explorer" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="40" HorizontalContentAlignment="Stretch" Style="{StaticResource FlatButton}" Click="ContextMenuCmd_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center" Width="30" TextAlignment="Center"/>
                            <TextBlock Text="Command Prompt" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="40" HorizontalContentAlignment="Stretch" Style="{StaticResource FlatButton}" Click="LaunchWindowsSettings_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center" Width="30" TextAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="#3a3a3a" Margin="5,5,5,5" Height="1"/>
                    <ItemsControl x:Name="StartMenuItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="2" Height="40" HorizontalContentAlignment="Stretch" Style="{StaticResource FlatButton}" Click="ShortcutButton_Click">
                                <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                    <Image Source="{Binding Icon}" Width="18" Height="18" VerticalAlignment="Center" Margin="6,0,6,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="PreviewPopup"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               VerticalOffset="-10">
            <Border Background="#1f1f1f"
                    CornerRadius="8"
                    Margin="10"
                    BorderBrush="#3a3a3a"
                    BorderThickness="1"
                    Padding="10">
                <ItemsControl x:Name="PreviewItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#eaeaea" Margin="0,0,0,8" TextTrimming="CharacterEllipsis" MaxWidth="200" HorizontalAlignment="Center"/>
                                <Border CornerRadius="4" Background="#111111" Margin="0,0,0,10" Cursor="Hand" PreviewMouseLeftButtonUp="PreviewImage_Click" Tag="{Binding Hwnd}">
                                    <Image Source="{Binding Thumbnail}" Width="200" Height="150" Stretch="Uniform"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Margin="0,0,5,0" Width="36" Height="36" ToolTip="Show in Explorer" Style="{StaticResource FlatButton}" Click="PreviewShowExplorer_Click" Tag="{Binding ProcessId}">
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                                    </Button>
                                    <Button Margin="0,0,5,0" Width="36" Height="36" ToolTip="Close Window" Style="{StaticResource FlatButton}" Click="PreviewClose_Click" Tag="{Binding Hwnd}">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16"/>
                                    </Button>
                                    <Button Width="36" Height="36" ToolTip="Terminate Process" Style="{StaticResource FlatButton}" Click="PreviewTerminate_Click" Tag="{Binding ProcessId}">
                                        <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="#ff5555"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>

        <Popup x:Name="TaskbarContextMenuPopup"
               Placement="Top"
               StaysOpen="False"
               AllowsTransparency="True"
               VerticalOffset="-10"
               Closed="TaskbarContextMenuPopup_Closed">
            <Border Background="#1f1f1f"
                    CornerRadius="8"
                    Margin="10"
                    BorderBrush="#3a3a3a"
                    BorderThickness="1">
                <StackPanel Margin="10" MinWidth="180">
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="TaskbarContextMenuClose_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock x:Name="TaskbarContextMenuCloseText" Text="Close" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="TaskbarContextMenuTerminate_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center" Foreground="#ff5555"/>
                            <TextBlock Text="Terminate" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0" Foreground="#ff5555"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="RightClickMenu"
               Placement="Top"
               PlacementTarget="{Binding ElementName=StartButton}"
               StaysOpen="False"
               AllowsTransparency="True"
               VerticalOffset="-10">
            <Border Width="230"
                    Background="#1f1f1f"
                    CornerRadius="8"
                    Margin="10"
                    BorderBrush="#3a3a3a"
                    BorderThickness="1">
                <StackPanel Margin="10">
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuSettings_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Start Menu Settings" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="#3a3a3a" Margin="5,5,5,5" Height="1"/>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuTaskManager_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Task Manager" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuCmd_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Command Prompt" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuRun_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Run..." VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="#3a3a3a" Margin="5,5,5,5" Height="1"/>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuSleep_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE708;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Sleep" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuSignOut_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xF3B1;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Sign Out" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuRestart_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Restart" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuRestartBios_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE9A1;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Restart to BIOS" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuShutDown_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center"/>
                            <TextBlock Text="Shut down" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Separator Background="#3a3a3a" Margin="5,5,5,5" Height="1"/>
                    <Button Margin="2" Height="36" HorizontalContentAlignment="Left" Style="{StaticResource FlatButton}" Click="ContextMenuQuit_Click">
                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons" FontSize="16" VerticalAlignment="Center" Width="24" TextAlignment="Center" Foreground="#ff5555"/>
                            <TextBlock Text="Quit Custom Shell" VerticalAlignment="Center" FontSize="14" Margin="10,0,0,0" Foreground="#ff5555"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

    </Grid>
</Window>