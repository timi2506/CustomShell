<Window x:Class="CustomShell.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Start Menu Settings" Height="400" Width="550"
        Background="#121212" Foreground="#eaeaea"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2b2b2b"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderBrush" Value="#3a3a3a"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#eaeaea"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Shortcuts" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
            <ListBox x:Name="ShortcutsList" Grid.Row="1" DisplayMemberPath="Name" SelectionChanged="ShortcutsList_SelectionChanged" Margin="0,0,0,10"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Content="Add" Click="AddButton_Click"/>
                <Button Content="Remove" Click="RemoveButton_Click"/>
            </StackPanel>
            <CheckBox x:Name="GroupWindowsCheckBox" Content="Group Taskbar Windows" Grid.Row="3" Margin="0,15,0,0" Foreground="#eaeaea"/>
            
            <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="16" Grid.Row="4" Margin="0,15,0,5"/>
            <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,10">
                <RadioButton x:Name="ThemeWin11Radio" Content="Windows 11" Foreground="#eaeaea" Margin="0,0,15,0"/>
                <RadioButton x:Name="ThemeWin10Radio" Content="Windows 10" Foreground="#eaeaea"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Edit Shortcut" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
            
            <StackPanel Grid.Row="1" x:Name="EditPanel" IsEnabled="False">
                <TextBlock Text="Name"/>
                <TextBox x:Name="NameTextBox" TextChanged="TextBox_TextChanged"/>
                
                <TextBlock Text="Target Path or Command"/>
                <TextBox x:Name="PathTextBox" TextChanged="TextBox_TextChanged"/>
                
                <TextBlock Text="Arguments (Optional)"/>
                <TextBox x:Name="ArgsTextBox" TextChanged="TextBox_TextChanged"/>

                <TextBlock Text="Icon Path (Optional)"/>
                <TextBox x:Name="IconPathTextBox" TextChanged="TextBox_TextChanged"/>
                <TextBlock Text="Note: Leave blank to use target path icon." FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="Note: For Windows Apps use commands like 'ms-settings:'" FontSize="11" Foreground="#888888" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Options" Click="SaveButton_Click" Background="#00a4ef" Foreground="White" BorderBrush="#0080ca"/>
                <Button Content="Cancel" Click="CancelButton_Click" Margin="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
